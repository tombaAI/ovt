# Povinné pro první deploy bez e-mailu.
# Na Vercelu použij jako DATABASE_URL connection string z Supabase Dashboard -> Connect.
# Pro serverless provoz je praktičtější transaction pooler connection string než přímé DB spojení.
DATABASE_URL=
ADMIN_EMAILS=admin@ovtbohemians.cz
# Volitelné. Pro první deploy na vercel.app URL ho zatím nepotřebuješ.
APP_BASE_URL=http://localhost:3000

# Volitelné až později pro e-mailing a cron.
# Pokud nastavíš jen RESEND_API_KEY, aplikace použije testovací sender onboarding@resend.dev.
# RESEND_API_KEY=
# MAIL_FROM=sprava@mail.ovtbohemians.cz
# MAIL_REPLY_TO=sprava@ovtbohemians.cz
# MAIL_TEST_TO=tvuj-email@example.com
# CRON_SECRET=change-me

# Volitelné až později, pokud začneš používat Supabase Auth nebo klientský Supabase SDK.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
